
@inherits FormComponent<CertificationOptions>

<FormCard
    @ref="Form"
    TOptions="CertificationOptions"
          Title="@Title"
          OnCancelled="OnCancelled"
          OnDeleted="OnDeleted"
          OnSaved="OnSaved"
          Options="Options">

    <Fields>
        <Validation>
            <Field ColumnSize="ColumnSize.Is4">
                <FieldLabel>Name</FieldLabel>
                <TextEdit Placeholder="Enter name" @bind-Text="Options.Name">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </Field>
        </Validation>
        <Validation>
            <Field ColumnSize="ColumnSize.Is4">
                <FieldLabel>Certification Body</FieldLabel>
                <TextEdit Placeholder="Enter certification body" @bind-Text="Options.Body">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </Field>
        </Validation>
        <Validation>
            <Field ColumnSize="ColumnSize.Is4">
                <FieldLabel>Date</FieldLabel>
                <DatePicker TValue="DateTime?" Placeholder="Enter date" @bind-Date="Options.Date">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </DatePicker>
            </Field>
        </Validation>
    </Fields>

</FormCard>
@using ResumePro.Shared.Models
<Card Margin="Margin.Is2.FromBottom">
    <CardHeader>
        <strong>@Job.JobTitle</strong> at @Job.Company
    </CardHeader>
    <CardBody>

        <CardSubtitle Margin="Margin.Is2.FromBottom" Italic="true">
            @Job.StartDate.ToShortDateString() - @(Job.DisplayEndDate) (@Job.Duration)
        </CardSubtitle>
        <CardText>
            @Job.Description
        </CardText>

        @if (Job.Highlights.Any())
        {
            <UnorderedList>
                @foreach (HighlightDto highlight in Job.Highlights)
                {
                    <UnorderedListItem>@highlight.Text</UnorderedListItem>
                }
            </UnorderedList>
        }

        @if (Job.Projects.Any())
        {
            <CardText>
                @foreach (ProjectDetails project in Job.Projects)
                {
                    <Heading Size="HeadingSize.Is5">Project: @project.Name</Heading>
                    <Paragraph>@project.Description</Paragraph>

                    @if (project.Highlights.Any())
                    {
                        <UnorderedList>
                            @foreach (HighlightDto highlight in project.Highlights)
                            {
                                <UnorderedListItem>@highlight.Text</UnorderedListItem>
                            }
                        </UnorderedList>
                    }
                }
            </CardText>
        }
        <CardText>
            <strong>Skills:</strong> @string.Join(", ", Job.Skills.Select(s => s.Name))
        </CardText>
    </CardBody>
</Card>
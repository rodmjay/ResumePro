@page "/people/{PersonId:int}/schools/create"
@inherits PersonPageBase

@if (Person != null)
{
    <div class="container sticky-top mt-3">
        <Breadcrumb>
            <BreadcrumbItem>
                <BreadcrumbLink To="/">People</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem>
                <BreadcrumbLink To="@($"/people/{PersonId}")">@Person.LastName, @Person.FirstName</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem Active>
                <BreadcrumbLink To="#">Create School</BreadcrumbLink>
            </BreadcrumbItem>
        </Breadcrumb>
    </div>

    <Container>
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnDesktop">
                <Card Margin="Margin.Is4.FromBottom">
                    <CardBody>
                        <CardTitle>Create School</CardTitle>

                        <SchoolFormComponent Options="Options" OnSaved="HandleValidSubmit" OnCancelled="HandleCancelled"></SchoolFormComponent>
                    </CardBody>
                </Card>
            </Column>
        </Row>
    </Container>
}


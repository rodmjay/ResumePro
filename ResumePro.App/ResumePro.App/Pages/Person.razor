@page "/people/{PersonId:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@if (@Persona != null)
{
    <div class="container sticky-top mt-3">
        <Breadcrumb>
            <BreadcrumbItem>
                <BreadcrumbLink To="/">People</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem Active>
                <BreadcrumbLink To="#">@Persona.LastName, @Persona.FirstName</BreadcrumbLink>
            </BreadcrumbItem>
        </Breadcrumb>
        
        <ul class="nav nav-tabs" id="resumeTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="basic-info-tab" data-bs-toggle="tab" data-bs-target="#basicInfo" type="button" role="tab" aria-controls="basicInfo" aria-selected="true">Person Details</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="resumes-tab" data-bs-toggle="tab" data-bs-target="#resumes" type="button" role="tab" aria-controls="resumes" aria-selected="false">Resumes (@Persona.ResumeCount) </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="jobs-tab" data-bs-toggle="tab" data-bs-target="#jobs" type="button" role="tab" aria-controls="jobs" aria-selected="false">Jobs (@Persona.JobCount) </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="education-tab" data-bs-toggle="tab" data-bs-target="#education" type="button" role="tab" aria-controls="education" aria-selected="false">Education </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="skills-tab" data-bs-toggle="tab" data-bs-target="#skills" type="button" role="tab" aria-controls="skills" aria-selected="false">Skills (@Persona.SkillCount)</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="certifications-tab" data-bs-toggle="tab" data-bs-target="#certifications" type="button" role="tab" aria-controls="certifications" aria-selected="false">Certifications</button>
            </li>
        </ul>

    </div>

    <div class="container mt-3">

        <!-- Tab Content -->
        <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade show active" id="basicInfo" role="tabpanel" aria-labelledby="basic-info-tab">
                <div class="p-4">
                    
                    <PersonContactInfoComponent Person="@Persona"></PersonContactInfoComponent>

                    <PersonLanguagesCard Person="@Persona"></PersonLanguagesCard>

                </div>
            </div>
            <div class="tab-pane fade" id="resumes" role="tabpanel" aria-labelledby="resumes-tab">
                <div class="p-4">
                    @if (Persona.Resumes != null && Persona.Resumes.Count > 0)
                    {
                        <div class="row">
                            @foreach (var resume in Persona.Resumes)
                            {
                                <ResumeCardComponent PersonId="@PersonId" Resume="@resume"></ResumeCardComponent>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No resumes to display.</p>
                    }

                </div>
            </div>
            <div class="tab-pane fade" id="jobs" role="tabpanel" aria-labelledby="jobs-tab">
                <div class="p-4">
                    @if (Persona.Jobs != null)
                    {
                        foreach (var job in Persona.Jobs)
                        {
                            <JobCardComponent Job="@job"></JobCardComponent>
                        }
                    }
                </div>
            </div>
            <div class="tab-pane fade" id="education" role="tabpanel" aria-labelledby="education-tab">
                <div class="p-4">
                    @if (Persona.Education != null)
                    {
                        foreach (var school in Persona.Education)
                        {
                            <div class="card mb-2">
                                <div class="card-body">
                                    <h5 class="card-title">@school.Name</h5>
                                    @foreach (var degree in school.Degrees)
                                    {
                                        <p class="card-text">@degree.Name</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="tab-pane fade" id="skills" role="tabpanel" aria-labelledby="skills-tab">
                <div class="p-4">
                    @if (Persona.Skills != null)
                    {
                        foreach (var skill in Persona.Skills)
                        {
                            <p>@skill.Name (@skill.Rating)</p>
                        }
                    }
                </div>
            </div>
            <div class="tab-pane fade" id="certifications" role="tabpanel" aria-labelledby="certifications-tab">
                <div class="p-4">
                    @if (Persona.Certifications != null)
                    {
                        foreach (var certification in Persona.Certifications)
                        {
                            <p>@certification.Name - Issued by: @certification.Body on @certification.Date.ToString("yyyy-MM-dd")</p>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}


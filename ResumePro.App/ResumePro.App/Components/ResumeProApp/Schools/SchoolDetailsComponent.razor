<Card Margin="Margin.Is2.FromBottom">
    <CardHeader>
        <Strong>@School.Name, @School.Location</Strong> (@School.StartDate.ToShortDateString() - @School.EndDate?.ToShortDateString())
    </CardHeader>
    <CardBody>
        <CardText>
            <UnorderedList>
                @foreach (var degree in School.Degrees)
                {
                    <UnorderedListItem>@degree.Name</UnorderedListItem>
                }
            </UnorderedList>
        </CardText>
    </CardBody>
</Card>
<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Contact Information</h5>
        <p class="mb-2">
            <strong>Email:</strong> 
            <a href="mailto:@Resume.Email">@Resume.Email</a>
        </p>
        <p class="mb-2">
            <strong>Phone:</strong> 
            <a href="tel:@Resume.PhoneNumber">@Resume.PhoneNumber</a>
        </p>
        <p class="mb-2">
            <strong>LinkedIn:</strong> 
            <a href="@Resume.LinkedIn" target="_blank">@Resume.LinkedIn</a>
        </p>
        <p class="mb-2">
            <strong>GitHub:</strong> 
            <a href="@Resume.GitHub" target="_blank">@Resume.GitHub</a>
        </p>
        <p class="mb-2">
            <strong>Location:</strong> 
            @Resume.City, @Resume.State, @Resume.Country
        </p>
    </div>
</div>
@inherits FormComponent<PersonaOptions>

<FormCard TOptions="PersonaOptions" Title="@Title" Options="Options" OnCancelled="@OnCancelled" OnSaved="@OnSaved">
    <Validation>
        <Field Horizontal> 
            <FieldLabel ColumnSize="ColumnSize.Is2">First Name</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter first name" @bind-Text="Options.FirstName">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">First Name</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter last name" @bind-Text="Options.LastName">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
            
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">
                City
            </FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter city" @bind-Text="Options.City">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
            
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel>State</FieldLabel>
            <FieldBody>
                <Select TValue="int" @bind-SelectedValue="@Options.StateId">

                    @foreach (var state in filterContainer.States)
                    {
                        <SelectItem Value="@(int.Parse(state.Value))">@state.Name</SelectItem>
                    }

                </Select>
            </FieldBody>
        </Field>
        </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">Email</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter email" @bind-Text="Options.Email">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
           
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">LinkedIn</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter linkedin" @bind-Text="Options.LinkedIn">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
          
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">GitHub</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter GitHub" @bind-Text="Options.GitHub">
                    <Feedback>
                        <ValidationError/>
                    </Feedback>
                </TextEdit>
            </FieldBody>
           
        </Field>
    </Validation>
</FormCard>
<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Contact Information</h5>
        <p class="mb-2">
            <strong>Email:</strong> 
            <a href="mailto:@Person.Email">@Person.Email</a>
        </p>
        <p class="mb-2">
            <strong>Phone:</strong> 
            <a href="tel:@Person.PhoneNumber">@Person.PhoneNumber</a>
        </p>
        <p class="mb-2">
            <strong>LinkedIn:</strong> 
            <a href="@Person.LinkedIn" target="_blank">@Person.LinkedIn</a>
        </p>
        <p class="mb-2">
            <strong>GitHub:</strong> 
            <a href="@Person.GitHub" target="_blank">@Person.GitHub</a>
        </p>
        <p class="mb-2">
            <strong>Location:</strong> 
            @Person.City, @Person.State, @Person.Country
        </p>
    </div>
</div>
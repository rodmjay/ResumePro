@inherits FormComponent<ReferenceOptions>

<FormCard TOptions="ReferenceOptions"
          Options="@Options"
          Title="@Title"
          OnDeleted="@OnDeleted"
          OnCancelled="@OnCancelled"
          OnSaved="@OnSaved">

    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">Reference Name</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is4">
                <TextEdit Placeholder="Enter name" @bind-Text="Options.Name">
                    <Feedback>
                        <ValidationError />
                    </Feedback>
                </TextEdit>
            </FieldBody>
        </Field>
    </Validation>
    <Validation>
        <Field Horizontal>
            <FieldLabel ColumnSize="ColumnSize.Is2">Reference Text</FieldLabel>
            <FieldBody ColumnSize="ColumnSize.Is8">
                <MemoEdit Rows="5" Placeholder="Enter text" @bind-Text="Options.Text">
                    <Feedback>
                        <ValidationError />
                    </Feedback>
                </MemoEdit>
            </FieldBody>

        </Field>
    </Validation>
    

</FormCard>
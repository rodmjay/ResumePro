@inherits FormComponent<ResumeOptions>

<Validations @ref="validationsRef" Mode="ValidationMode.Auto" ValidateOnLoad="false">
    <Validation Validator="@ValidationRule.IsNotEmpty">
        <Field>
            <FieldLabel>Title</FieldLabel>
            <TextEdit Placeholder="Enter title" @bind-Text="Options.JobTitle" />
        </Field>
    </Validation>
    <Validation Validator="@ValidationRule.IsNotEmpty">
        <Field>
            <FieldLabel>Description</FieldLabel>
            <MemoEdit Rows="10" Placeholder="Enter description" @bind-Text="Options.Description" />
        </Field>
    </Validation>

    <Field>
        <Button Color="Color.Primary" Clicked="HandleValidSubmit">Submit</Button>
        <Button Color="Color.Secondary" Clicked="Cancel">Cancel</Button>

    </Field>
</Validations>
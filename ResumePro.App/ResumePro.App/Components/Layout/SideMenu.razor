<Bar Breakpoint="Breakpoint.Desktop" NavigationBreakpoint="Breakpoint.Tablet" ThemeContrast="ThemeContrast.Dark"
     Mode="BarMode.VerticalInline" CollapseMode="BarCollapseMode.Small">
    <BarToggler/>
    <BarBrand>
        <BarItem>
            <BarLink To="">
                <BarIcon IconName="customIcon"/>
                ResumePro.App
            </BarLink>
        </BarItem>
    </BarBrand>
    <BarMenu>
        <BarStart>
            <BarItem>
                <BarLink To="/">
                    <BarIcon IconName="IconName.Dashboard"/>
                    People
                </BarLink>
            </BarItem>
            <BarItem>
                <BarLink To="/templates">
                    <BarIcon IconName="IconName.Dashboard" />
                    Templates
                </BarLink>
            </BarItem>
          
        </BarStart>
        <BarEnd>
            <BarItem>
                <BarDropdown>
                    <BarDropdownToggle>
                        <BarIcon IconName="IconName.Settings"/>
                        Settings
                    </BarDropdownToggle>
                    <BarDropdownMenu>
                        <BarDropdownItem To="/apps/todo">
                            Settings
                        </BarDropdownItem>
                    </BarDropdownMenu>
                </BarDropdown>
            </BarItem>
        </BarEnd>
    </BarMenu>
</Bar>

@code {
    private bool pagesBarVisible = true;

    RenderFragment customIcon = @<img src="/brand-logo.png" style="height: 32px; width: 32px;"/>;

}
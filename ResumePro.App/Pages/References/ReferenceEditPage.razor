@page "/people/{PersonId:int}/references/{ReferenceId:int}/edit"
@inherits PersonPageBase

@if (Person != null)
{
    <div class="container sticky-top mt-3">
        <Breadcrumb>
            <BreadcrumbItem>
                <BreadcrumbLink To="/">People</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem>
                <BreadcrumbLink To="@($"/people/{PersonId}")">@Person.LastName, @Person.FirstName</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem Active>
                <BreadcrumbLink To="#">Edit Reference</BreadcrumbLink>
            </BreadcrumbItem>
        </Breadcrumb>
    </div>
    <Container>
        <Row>
            <Column ColumnSize="ColumnSize.IsFull.OnDesktop">
                <ReferenceFormComponent Title="Edit Reference"
                                        OnDeleted="HandleDelete"
                                        OnSaved="HandleValidSubmit"
                                        OnCancelled="HandleCancelled"
                                        Options="Options">

                </ReferenceFormComponent>
            </Column>
        </Row>
    </Container>
}
@page "/people/{PersonId:int}/companies/{JobId:int}/edit"
@using ResumePro.App.Components.Companies
@inherits PersonPageBase

@if (Company != null)
{
    <div class="container sticky-top mt-3">
        <Breadcrumb>
            <BreadcrumbItem>
                <BreadcrumbLink To="/">People</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem>
                <BreadcrumbLink To="@($"/people/{PersonId}")">@Person.LastName, @Person.FirstName</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbItem Active>
                <BreadcrumbLink To="#">Edit Job: @Company.JobTitle, @Company.CompanyName</BreadcrumbLink>
            </BreadcrumbItem>
        </Breadcrumb>
    </div>
    <Container>
        <Row>
            <Column ColumnSize="ColumnSize.IsFull.OnDesktop">
                <JobFormComponent @ref="Form" PersonId="@PersonId" Title="Edit Job" Options="Options" OnSaved="HandleValidSubmit" OnCancelled="HandleCancelled" OnDeleted="HandleDelete"></JobFormComponent>
            </Column>
        </Row>
    </Container>
}